<style>
  .ncdr-sim-home {
    padding: 64px 60px;
    background: #fff;
    border-bottom: 1px solid var(--ncdr-light-gray);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .ncdr-sim-home__eyebrow {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ncdr-gold);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .ncdr-sim-home__eyebrow span {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--ncdr-gold);
    opacity: 0.4;
  }

  .ncdr-sim-home__heading {
    font-family: var(--ncdr-font-heading);
    font-size: 28px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--ncdr-green-deep);
    margin-bottom: 6px;
    line-height: 1.1;
  }

  .ncdr-sim-home__sub {
    font-size: 14px;
    color: var(--ncdr-text-mid);
    font-weight: 400;
    letter-spacing: 0.04em;
    margin-bottom: 16px;
  }

  .ncdr-sim-home__body {
    font-size: 15px;
    color: var(--ncdr-text-mid);
    font-weight: 300;
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .ncdr-sim-home__btn {
    display: inline-block;
    background: var(--ncdr-green-deep);
    color: #fff;
    font-family: var(--ncdr-font-heading);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 13px 32px;
    border-radius: 3px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .ncdr-sim-home__btn:hover {
    background: var(--ncdr-green);
    color: #fff;
    text-decoration: none;
  }

  .ncdr-sim-home__image {
    border-radius: 6px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--ncdr-light-gray);
  }
  .ncdr-sim-home__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 749px) {
    .ncdr-sim-home {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 48px 20px;
    }
    .ncdr-sim-home__image { order: -1; }
    .ncdr-sim-home__heading { font-size: 22px; }
  }
</style>

<div class="ncdr-sim-home">
  <div class="ncdr-sim-home__content">
    <div class="ncdr-sim-home__eyebrow">{{ section.settings.eyebrow }} <span></span></div>
    <h2 class="ncdr-sim-home__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.sub != blank -%}
      <p class="ncdr-sim-home__sub">{{ section.settings.sub }}</p>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="ncdr-sim-home__body">{{ section.settings.body }}</p>
    {%- endif -%}
    <a href="{{ section.settings.cta_link | default: '/pages/contact' }}" class="ncdr-sim-home__btn">
      {{ section.settings.cta_label | default: 'Contact Us' }}
    </a>
  </div>
  <div class="ncdr-sim-home__image">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.image.alt | default: 'Golfzon Simulators' }}
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "NCDR Simulator Home",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Simulators" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Golfzon Simulators" },
    { "type": "text", "id": "sub", "label": "Subheading", "default": "Year-round golf, rain or shine." },
    { "type": "textarea", "id": "body", "label": "Body text", "default": "Don't let the weather dictate your game. Play the world's most iconic courses indoors, in full comfort, no matter the season." },
    { "type": "text", "id": "cta_label", "label": "Button label", "default": "Contact Us" },
    { "type": "url", "id": "cta_link", "label": "Button link" },
    { "type": "image_picker", "id": "image", "label": "Image" }
  ],
  "presets": [{ "name": "NCDR Simulator Home" }]
}
{% endschema %}
