<style>
  .ncdr-footer {
    background: var(--ncdr-footer-bg);
    border-top: 1px solid rgba(201,168,76,0.15);
    padding: 56px 60px 32px;
  }

  .ncdr-footer__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    margin-bottom: 48px;
  }

  /* Brand column */
  .ncdr-footer__brand-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    text-decoration: none;
  }

  .ncdr-footer__brand-name {
    font-family: var(--ncdr-font-heading);
    font-size: 16px;
    font-weight: 600;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .ncdr-footer__tagline {
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    line-height: 1.7;
    max-width: 220px;
    margin-bottom: 20px;
    font-weight: 300;
  }

  .ncdr-footer__contact {
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    line-height: 1.9;
    letter-spacing: 0.02em;
  }

  .ncdr-footer__contact a {
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    transition: color 0.2s;
  }
  .ncdr-footer__contact a:hover { color: var(--ncdr-gold); }

  /* Link columns */
  .ncdr-footer__col-title {
    font-family: var(--ncdr-font-heading);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 16px;
  }

  .ncdr-footer__links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ncdr-footer__links a {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    text-decoration: none;
    font-weight: 300;
    transition: color 0.2s;
  }
  .ncdr-footer__links a:hover { color: var(--ncdr-gold); }

  /* Bottom row */
  .ncdr-footer__bottom {
    padding-top: 28px;
    border-top: 1px solid rgba(255,255,255,0.05);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .ncdr-footer__copy {
    font-size: 11px;
    color: rgba(255,255,255,0.2);
    letter-spacing: 0.04em;
    width: 100%;
    text-align: center;
  }

  .ncdr-footer__badges {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .ncdr-footer__badges img {
    height: 148px;
    width: auto;
    opacity: 0.85;
    transition: opacity 0.2s;
  }
  .ncdr-footer__badges img:hover { opacity: 1; }

  @media (max-width: 1024px) {
    .ncdr-footer__grid { grid-template-columns: repeat(2, 1fr); gap: 36px; }
  }

  @media (max-width: 749px) {
    .ncdr-footer { padding: 48px 20px 28px; }
    .ncdr-footer__grid { grid-template-columns: 1fr 1fr; gap: 28px; }
    .ncdr-footer__bottom { flex-direction: column; align-items: flex-start; }
  }

  @media (max-width: 480px) {
    .ncdr-footer__grid { grid-template-columns: 1fr; }
  }
</style>

<footer class="ncdr-footer">
  <div class="ncdr-footer__grid">

    <!-- Brand column -->
    <div>
      <a href="{{ routes.root_url }}" class="ncdr-footer__brand-logo">
        <span class="ncdr-footer__brand-name">Northcrest Golf</span>
      </a>
      <p class="ncdr-footer__tagline">Atlanta's premier driving range since 1986. Open late, rain or shine, 365 days a year.</p>
      <div class="ncdr-footer__contact">
        3545 Northcrest Road, Atlanta, GA 30340<br>
        <a href="tel:+17707230002">(770) 723-0002</a><br>
        <a href="mailto:northcrestgolfshop@gmail.com">northcrestgolfshop@gmail.com</a>
      </div>
    </div>

    <!-- Badge column -->
    <div>
      <div class="ncdr-footer__badges">
        <img src="{{ 'Majesty_Authorized_Dealer_Certificate.png' | asset_url }}" alt="Majesty Authorized Dealer" loading="lazy">
        <img src="{{ 'Honma_Verified_Retailer_Certificate.png' | asset_url }}" alt="Honma Verified Retailer" loading="lazy">
      </div>
    </div>

    <!-- Shop column -->
    <div>
      <div class="ncdr-footer__col-title">Shop</div>
      <ul class="ncdr-footer__links">
        <li><a href="/collections/clubs">Clubs</a></li>
        <li><a href="/collections/balls">Balls</a></li>
        <li><a href="/collections/gear-and-tech">Gear &amp; Tech</a></li>
        <li><a href="/collections/accessories">Accessories</a></li>
        <li><a href="/collections/apparel">Apparel</a></li>
      </ul>
    </div>

    <!-- Experience column -->
    <div>
      <div class="ncdr-footer__col-title">Experience</div>
      <ul class="ncdr-footer__links">
        <li><a href="/pages/events">Events</a></li>
        <li><a href="/pages/lesson">Lesson</a></li>
        <li><a href="/pages/repair">Repair</a></li>
        <li><a href="/pages/trade-in">Trade-In</a></li>
      </ul>
    </div>

    <!-- Info column -->
    <div>
      <div class="ncdr-footer__col-title">Info</div>
      <ul class="ncdr-footer__links">
        <li><a href="/pages/contact">About Us</a></li>
        <li><a href="/pages/contact">Contact</a></li>
        <li><a href="/pages/contact">Hours &amp; Location</a></li>
      </ul>
    </div>

  </div>

  <!-- Bottom row -->
  <div class="ncdr-footer__bottom">
    <div class="ncdr-footer__copy">
      &copy; {{ 'now' | date: '%Y' }} Northcrest Golf Driving Range. All rights reserved.
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "settings": [
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    }
  ]
}
{% endschema %}
