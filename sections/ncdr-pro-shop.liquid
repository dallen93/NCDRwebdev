<style>
  .ncdr-pro-shop {
    padding: 64px 60px;
    background: #fff;
    border-top: 1px solid var(--ncdr-light-gray);
  }

  .ncdr-pro-shop__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 36px;
  }

  .ncdr-pro-shop__eyebrow {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ncdr-gold);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .ncdr-pro-shop__eyebrow span {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--ncdr-gold);
    opacity: 0.4;
  }

  .ncdr-pro-shop__heading {
    font-family: var(--ncdr-font-heading);
    font-size: 32px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--ncdr-text-dark);
    margin-bottom: 6px;
    line-height: 1.1;
  }

  .ncdr-pro-shop__sub {
    font-size: 14px;
    color: var(--ncdr-text-mid);
    font-weight: 300;
    margin: 0;
  }

  .ncdr-pro-shop__view-all {
    font-family: var(--ncdr-font-heading);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ncdr-green);
    text-decoration: none;
    border-bottom: 1px solid rgba(58,88,43,0.3);
    padding-bottom: 2px;
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: 40px;
    margin-bottom: 4px;
  }
  .ncdr-pro-shop__view-all:hover { border-color: var(--ncdr-green); }

  .ncdr-pro-shop__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .ncdr-pcard {
    border: 1px solid var(--ncdr-light-gray);
    border-radius: 6px;
    overflow: hidden;
    background: #fff;
    transition: box-shadow 0.2s, transform 0.2s;
    text-decoration: none;
    display: block;
  }
  .ncdr-pcard:hover {
    box-shadow: 0 8px 28px rgba(0,0,0,0.09);
    transform: translateY(-2px);
  }

  .ncdr-pcard__img {
    aspect-ratio: 1;
    background: var(--ncdr-off-white);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .ncdr-pcard__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ncdr-pcard__img-placeholder {
    width: 60px;
    height: 60px;
    opacity: 0.18;
  }

  .ncdr-pcard__badge {
    position: absolute;
    top: 10px;
    left: 10px;
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 2px;
  }
  .ncdr-pcard__badge--gold {
    background: var(--ncdr-gold);
    color: var(--ncdr-green-deep);
  }
  .ncdr-pcard__badge--green {
    background: var(--ncdr-green);
    color: #fff;
  }

  .ncdr-pcard__info {
    padding: 16px;
  }

  .ncdr-pcard__brand {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ncdr-gold);
    margin-bottom: 4px;
  }

  .ncdr-pcard__name {
    font-family: var(--ncdr-font-heading);
    font-size: 15px;
    font-weight: 600;
    color: var(--ncdr-text-dark);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.2;
    margin-bottom: 12px;
  }

  .ncdr-pcard__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .ncdr-pcard__price {
    font-family: var(--ncdr-font-heading);
    font-size: 20px;
    font-weight: 700;
    color: var(--ncdr-green-deep);
  }

  .ncdr-pcard__cart {
    width: 34px;
    height: 34px;
    background: var(--ncdr-green-deep);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  .ncdr-pcard:hover .ncdr-pcard__cart { background: var(--ncdr-green); }
  .ncdr-pcard__cart svg { stroke: #fff; }

  .ncdr-pro-shop__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 60px 20px;
    color: var(--ncdr-text-mid);
    font-size: 14px;
    font-weight: 300;
  }

  @media (max-width: 1024px) {
    .ncdr-pro-shop__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 749px) {
    .ncdr-pro-shop { padding: 48px 20px; }
    .ncdr-pro-shop__header { flex-direction: column; align-items: flex-start; gap: 16px; }
    .ncdr-pro-shop__view-all { margin-left: 0; }
    .ncdr-pro-shop__grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }
</style>

{%- liquid
  assign shop_collection = collections[section.settings.collection]
  assign products_to_show = section.settings.products_to_show | default: 4
-%}

<div class="ncdr-pro-shop">
  <div class="ncdr-pro-shop__header">
    <div>
      <div class="ncdr-pro-shop__eyebrow">Pro Shop <span></span></div>
      <h2 class="ncdr-pro-shop__heading">{{ section.settings.heading }}</h2>
      <p class="ncdr-pro-shop__sub">{{ section.settings.subtext }}</p>
    </div>
    {%- if section.settings.view_all_link != blank -%}
      <a href="{{ section.settings.view_all_link }}" class="ncdr-pro-shop__view-all">
        {{ section.settings.view_all_label | default: 'View All Products →' }}
      </a>
    {%- endif -%}
  </div>

  <div class="ncdr-pro-shop__grid">
    {%- if shop_collection != blank and shop_collection.products_count > 0 -%}
      {%- for product in shop_collection.products limit: products_to_show -%}
        {%- liquid
          assign badge_label = ''
          assign badge_class = ''
          for tag in product.tags
            assign tag_down = tag | downcase
            if tag_down == 'new release' or tag_down == 'new-release'
              assign badge_label = 'New Release'
              assign badge_class = 'ncdr-pcard__badge--gold'
              break
            endif
            if tag_down == 'in stock'
              assign badge_label = 'In Stock'
              assign badge_class = 'ncdr-pcard__badge--green'
            endif
          endfor
        -%}
        <a href="{{ product.url }}" class="ncdr-pcard">
          <div class="ncdr-pcard__img">
            {%- if badge_label != blank -%}
              <div class="ncdr-pcard__badge {{ badge_class }}">{{ badge_label }}</div>
            {%- endif -%}
            {%- if product.featured_image -%}
              <img
                src="{{ product.featured_image | image_url: width: 600 }}"
                alt="{{ product.featured_image.alt | escape }}"
                width="600"
                height="600"
                loading="lazy"
              >
            {%- else -%}
              <svg class="ncdr-pcard__img-placeholder" viewBox="0 0 60 60" fill="none">
                <ellipse cx="30" cy="48" rx="18" ry="7" stroke="#3A582B" stroke-width="1.5"/>
                <line x1="30" y1="41" x2="30" y2="16" stroke="#3A582B" stroke-width="1.5"/>
                <ellipse cx="30" cy="14" rx="7" ry="3.5" stroke="#3A582B" stroke-width="1.5"/>
              </svg>
            {%- endif -%}
          </div>
          <div class="ncdr-pcard__info">
            <div class="ncdr-pcard__brand">{{ product.vendor }}</div>
            <div class="ncdr-pcard__name">{{ product.title }}</div>
            <div class="ncdr-pcard__footer">
              <div class="ncdr-pcard__price">{{ product.price | money }}</div>
              <div class="ncdr-pcard__cart">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
                  <line x1="3" y1="6" x2="21" y2="6"/>
                  <path d="M16 10a4 4 0 01-8 0"/>
                </svg>
              </div>
            </div>
          </div>
        </a>
      {%- endfor -%}
    {%- else -%}
      <div class="ncdr-pro-shop__empty">
        Products coming soon. <a href="{{ section.settings.view_all_link | default: '/collections/all' }}" style="color:var(--ncdr-green);font-weight:500;">Browse the pro shop →</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "NCDR Pro Shop Grid",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "New Gear. Now In Stock." },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Premium Japanese and American brands — curated for every level of player." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "products_to_show", "label": "Products to show", "min": 2, "max": 8, "step": 2, "default": 4 },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View All Products →" },
    { "type": "url", "id": "view_all_link", "label": "View all link" }
  ],
  "presets": [
    { "name": "NCDR Pro Shop Grid" }
  ]
}
{% endschema %}
