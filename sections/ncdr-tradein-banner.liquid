<style>
  .ncdr-tradein-section {
    background: #fff;
    padding: 7.2rem 6rem;
    border-top: 1px solid var(--ncdr-light-gray);
  }

  .ncdr-tradein-inner {
    background: #fff;
    border: 1px solid var(--ncdr-light-gray);
    border-radius: 8px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  }

  .ncdr-tradein-content {
    padding: 4.8rem;
    background: #fff;
    border-right: 1px solid var(--ncdr-light-gray);
  }

  .ncdr-tradein-steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 2.8rem;
  }

  .ncdr-tradein-step {
    display: flex;
    gap: 1.6rem;
    align-items: flex-start;
  }

  .ncdr-step-num {
    width: 28px;
    height: 28px;
    background: var(--ncdr-green);
    color: #fff;
    border-radius: 50%;
    font-family: var(--ncdr-font-heading);
    font-size: 1.2rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .ncdr-step-title {
    font-family: var(--ncdr-font-heading);
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--ncdr-text-dark);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 3px;
  }

  .ncdr-step-body {
    font-size: 1.2rem;
    color: var(--ncdr-text-mid);
    line-height: 1.55;
    font-weight: 300;
  }

  .ncdr-tradein-cta-panel {
    padding: 4.8rem;
    background: var(--ncdr-green-deep);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ncdr-tradein-cta-title {
    font-family: var(--ncdr-font-heading);
    font-size: 2.8rem;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.1;
    margin-bottom: 1.6rem;
  }

  .ncdr-tradein-cta-title span { color: var(--ncdr-gold); display: block; }

  .ncdr-tradein-cta-sub {
    font-size: 1.4rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    margin-bottom: 3.2rem;
    font-weight: 300;
  }

  @media (max-width: 749px) {
    .ncdr-tradein-section { padding: 4.8rem 2rem; }
    .ncdr-tradein-inner { grid-template-columns: 1fr; }
    .ncdr-tradein-content { border-right: none; border-bottom: 1px solid var(--ncdr-light-gray); }
  }
</style>

<div class="ncdr-tradein-section">
  <div class="ncdr-tradein-inner">
    <div class="ncdr-tradein-content">
      <p class="ncdr-eyebrow">Trade-Ins</p>
      <h2 style="font-family:var(--ncdr-font-heading);font-size:3.2rem;font-weight:700;text-transform:uppercase;letter-spacing:0.02em;margin-bottom:8px;color:var(--ncdr-text-dark);">
        {{ section.settings.heading }}
      </h2>
      <p style="font-size:1.5rem;color:var(--ncdr-text-mid);margin-bottom:0;font-weight:300;">{{ section.settings.subheading }}</p>

      <div class="ncdr-tradein-steps">
        <div class="ncdr-tradein-step">
          <div class="ncdr-step-num">1</div>
          <div>
            <div class="ncdr-step-title">{{ section.settings.step1_title }}</div>
            <div class="ncdr-step-body">{{ section.settings.step1_body }}</div>
          </div>
        </div>
        <div class="ncdr-tradein-step">
          <div class="ncdr-step-num">2</div>
          <div>
            <div class="ncdr-step-title">{{ section.settings.step2_title }}</div>
            <div class="ncdr-step-body">{{ section.settings.step2_body }}</div>
          </div>
        </div>
        <div class="ncdr-tradein-step">
          <div class="ncdr-step-num">3</div>
          <div>
            <div class="ncdr-step-title">{{ section.settings.step3_title }}</div>
            <div class="ncdr-step-body">{{ section.settings.step3_body }}</div>
          </div>
        </div>
      </div>
    </div>

    <div class="ncdr-tradein-cta-panel">
      <h3 class="ncdr-tradein-cta-title">
        Trade In.<span>Upgrade.</span>
      </h3>
      <p class="ncdr-tradein-cta-sub">{{ section.settings.cta_body }}</p>
      <a href="{{ section.settings.cta_link | default: '/pages/trade-ins' }}" class="button button--primary button--gold">
        {{ section.settings.cta_label }}
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "NCDR Trade-In Banner",
  "tag": "div",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Trade In. Upgrade. Play Better." },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Get store credit for your old clubs — applied instantly to your NCDR account." },
    { "type": "text", "id": "step1_title", "label": "Step 1 Title", "default": "Submit Online or In-Store" },
    { "type": "textarea", "id": "step1_body", "label": "Step 1 Body", "default": "Fill out the form with your club details, or bring your clubs directly to the pro shop at 3545 Northcrest Road." },
    { "type": "text", "id": "step2_title", "label": "Step 2 Title", "default": "Get Your Trade-In Value" },
    { "type": "textarea", "id": "step2_body", "label": "Step 2 Body", "default": "Our team assesses your clubs and provides an instant credit offer based on brand, model, and condition." },
    { "type": "text", "id": "step3_title", "label": "Step 3 Title", "default": "Credit Applied to Your Account" },
    { "type": "textarea", "id": "step3_body", "label": "Step 3 Body", "default": "Store credit lands in your NCDR account immediately — use it online in the pro shop or in-store at the range." },
    { "type": "textarea", "id": "cta_body", "label": "CTA Panel Body", "default": "Get store credit for your old clubs, applied instantly to your account. Use it online or in-store." },
    { "type": "text", "id": "cta_label", "label": "CTA Button Label", "default": "Start Trade-In" },
    { "type": "url", "id": "cta_link", "label": "CTA Button Link" }
  ],
  "presets": [
    { "name": "NCDR Trade-In Banner" }
  ]
}
{% endschema %}
