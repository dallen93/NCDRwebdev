<style>
  /* ── Event Types ── */
  .ncdr-events {
    padding: 64px 60px;
    background: var(--ncdr-off-white);
    border-bottom: 1px solid var(--ncdr-light-gray);
  }

  .ncdr-events__eyebrow {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ncdr-gold);
    margin-bottom: 0px;
    display: flex;
    align-items: center;
    gap: 0px;
  }
  .ncdr-events__eyebrow span {
    display: inline-block;
    width: 24px;
    height: 0px;
    background: var(--ncdr-gold);
    opacity: 0.4;
  }

  .ncdr-events__heading {
    font-family: var(--ncdr-font-heading);
    font-size: 28px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: 8px;
  }

  .ncdr-events__sub {
    font-size: 14px;
    color: var(--ncdr-text-mid);
    font-weight: 300;
    max-width: 520px;
    margin-bottom: 36px;
    line-height: 1.65;
  }

  .ncdr-events__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .ncdr-event-card {
    background: #fff;
    border: 1px solid var(--ncdr-light-gray);
    border-radius: 8px;
    padding: 28px 24px;
  }

  .ncdr-event-card__icon {
    width: 40px;
    height: 40px;
    background: var(--ncdr-green-deep);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .ncdr-event-card__name {
    font-family: var(--ncdr-font-heading);
    font-size: 15px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--ncdr-text-dark);
    margin-bottom: 8px;
  }

  .ncdr-event-card__desc {
    font-size: 13px;
    color: var(--ncdr-text-mid);
    line-height: 1.7;
    font-weight: 300;
  }

  /* ── Inquiry Form ── */
  .ncdr-events-form {
    padding: 64px 60px;
    background: #fff;
    border-bottom: 1px solid var(--ncdr-light-gray);
  }

  .ncdr-events-form__eyebrow {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ncdr-gold);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .ncdr-events-form__eyebrow span {
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--ncdr-gold);
    opacity: 0.4;
  }

  .ncdr-events-form__heading {
    font-family: var(--ncdr-font-heading);
    font-size: 28px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: 8px;
  }

  .ncdr-events-form__sub {
    font-size: 14px;
    color: var(--ncdr-text-mid);
    font-weight: 300;
    margin-bottom: 36px;
    max-width: 520px;
    line-height: 1.65;
  }

  .ncdr-events-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    max-width: 720px;
  }

  .ncdr-events-form__field {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .ncdr-events-form__field--full {
    grid-column: 1 / -1;
  }

  .ncdr-events-form__label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ncdr-text-mid);
  }

  .ncdr-events-form__input {
    border: 1px solid var(--ncdr-light-gray);
    border-radius: 4px;
    padding: 10px 12px;
    font-size: 13px;
    font-family: var(--ncdr-font-body);
    color: var(--ncdr-text-dark);
    background: #fff;
    transition: border-color 0.2s;
    width: 100%;
    box-sizing: border-box;
  }
  .ncdr-events-form__input:focus {
    outline: none;
    border-color: var(--ncdr-gold);
  }

  textarea.ncdr-events-form__input { resize: vertical; }

  .ncdr-events-form__submit {
    margin-top: 8px;
    background: var(--ncdr-green-deep);
    color: #fff;
    font-family: var(--ncdr-font-heading);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 13px 32px;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    transition: background 0.2s;
  }
  .ncdr-events-form__submit:hover { background: var(--ncdr-green); }

  @media (max-width: 749px) {
    .ncdr-events,
    .ncdr-events-form { padding: 48px 20px; }
    .ncdr-events__grid { grid-template-columns: 1fr; }
    .ncdr-events-form__grid { grid-template-columns: 1fr; }
  }
</style>

<!-- Event Types -->
<div class="ncdr-events">
  <div class="ncdr-events__eyebrow">{{ section.settings.types_eyebrow }} <span></span></div>
  <h2 class="ncdr-events__heading">{{ section.settings.types_heading }}</h2>
  <p class="ncdr-events__sub">{{ section.settings.types_subtext }}</p>

  <div class="ncdr-events__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'event_type' -%}
        <div class="ncdr-event-card">
          <div class="ncdr-event-card__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--ncdr-gold)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
          </div>
          <div class="ncdr-event-card__name">{{ block.settings.name }}</div>
          <div class="ncdr-event-card__desc">{{ block.settings.description }}</div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<!-- Inquiry Form -->
<div class="ncdr-events-form">
  <div class="ncdr-events-form__eyebrow">{{ section.settings.form_eyebrow }} <span></span></div>
  <h2 class="ncdr-events-form__heading">{{ section.settings.form_heading }}</h2>
  <p class="ncdr-events-form__sub">{{ section.settings.form_subtext }}</p>

  {% form 'contact' %}
    {%- if form.posted_successfully? -%}
      <p style="color:var(--ncdr-green);font-weight:600;margin-bottom:20px;">Thanks! We'll be in touch shortly to discuss your event.</p>
    {%- endif -%}
    {%- if form.errors -%}
      <p style="color:#c0392b;margin-bottom:12px;">{{ form.errors | default_errors }}</p>
    {%- endif -%}

    <div class="ncdr-events-form__grid">
      <div class="ncdr-events-form__field">
        <label class="ncdr-events-form__label" for="event-name">Name</label>
        <input class="ncdr-events-form__input" type="text" id="event-name" name="contact[name]" required placeholder="Your full name">
      </div>
      <div class="ncdr-events-form__field">
        <label class="ncdr-events-form__label" for="event-email">Email</label>
        <input class="ncdr-events-form__input" type="email" id="event-email" name="contact[email]" required placeholder="your@email.com">
      </div>
      <div class="ncdr-events-form__field">
        <label class="ncdr-events-form__label" for="event-phone">Phone</label>
        <input class="ncdr-events-form__input" type="tel" id="event-phone" name="contact[phone]" required placeholder="(xxx) xxx-xxxx">
      </div>
      <div class="ncdr-events-form__field">
        <label class="ncdr-events-form__label" for="event-type">Event Type</label>
        <select class="ncdr-events-form__input" id="event-type" name="contact[event_type]">
          <option value="">Select event type</option>
          <option>Birthday Party</option>
          <option>Corporate Event / Team Outing</option>
          <option>Indoor Golf Tournament</option>
          <option>School / Youth Group</option>
          <option>Family Gathering</option>
          <option>Private Celebration</option>
          <option>Other</option>
        </select>
      </div>
      <div class="ncdr-events-form__field">
        <label class="ncdr-events-form__label" for="event-date">Preferred Date</label>
        <input class="ncdr-events-form__input" type="date" id="event-date" name="contact[preferred_date]">
      </div>
      <div class="ncdr-events-form__field">
        <label class="ncdr-events-form__label" for="event-guests">Estimated Guest Count</label>
        <input class="ncdr-events-form__input" type="number" id="event-guests" name="contact[guest_count]" placeholder="e.g. 20" min="1">
      </div>
      <div class="ncdr-events-form__field ncdr-events-form__field--full">
        <label class="ncdr-events-form__label" for="event-message">Additional Details</label>
        <textarea class="ncdr-events-form__input" id="event-message" name="contact[body]" rows="4" placeholder="Tell us about your event, any special requests, or questions…"></textarea>
      </div>
    </div>
    <button type="submit" class="ncdr-events-form__submit">Submit Inquiry</button>
  {% endform %}
</div>

{% schema %}
{
  "name": "NCDR Events",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "types_eyebrow", "label": "Event types eyebrow", "default": "What We Can Do For You" },
    { "type": "text", "id": "types_heading", "label": "Event types heading", "default": "Events We Host" },
    { "type": "textarea", "id": "types_subtext", "label": "Event types subtext", "default": "Whether you're planning something casual or competitive, Northcrest is equipped to host events of all sizes and skill levels." },
    { "type": "text", "id": "form_eyebrow", "label": "Form eyebrow", "default": "Start Planning" },
    { "type": "text", "id": "form_heading", "label": "Form heading", "default": "Start Planning Your Event" },
    { "type": "textarea", "id": "form_subtext", "label": "Form subtext", "default": "Share a few details below and our team will follow up to discuss availability, pricing, and next steps." }
  ],
  "blocks": [
    {
      "type": "event_type",
      "name": "Event Type",
      "settings": [
        { "type": "text", "id": "name", "label": "Event name" },
        { "type": "textarea", "id": "description", "label": "Description" }
      ]
    }
  ],
  "presets": [{ "name": "NCDR Events" }]
}
{% endschema %}
