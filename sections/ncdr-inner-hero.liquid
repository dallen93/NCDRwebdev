<style>
  .ncdr-inner-hero {
    background: var(--ncdr-green-deep);
    padding: 56px 60px 48px;
    position: relative;
    overflow: hidden;
  }

  .ncdr-inner-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      45deg,
      rgba(255,255,255,0.012) 0px,
      rgba(255,255,255,0.012) 1px,
      transparent 1px,
      transparent 28px
    );
    pointer-events: none;
  }

  .ncdr-inner-hero__content {
    position: relative;
    z-index: 2;
    max-width: 680px;
  }

  .ncdr-inner-hero__eyebrow {
    font-family: var(--ncdr-font-heading);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ncdr-gold);
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ncdr-inner-hero__eyebrow::after {
    content: '';
    display: block;
    width: 28px;
    height: 1px;
    background: var(--ncdr-gold);
    opacity: 0.4;
  }

  .ncdr-inner-hero__heading {
    font-family: var(--ncdr-font-heading) !important;
    font-size: 48px;
    font-weight: 700;
    color: #fff;
    text-transform: uppercase;
    line-height: 1.0;
    margin-bottom: 14px;
    letter-spacing: 0.02em;
  }

  .ncdr-inner-hero__heading span {
    color: var(--ncdr-gold);
    display: block;
  }

  .ncdr-inner-hero__sub {
    font-size: 15px;
    color: rgba(255,255,255,0.6);
    max-width: 480px;
    line-height: 1.7;
    font-weight: 300;
    margin: 0;
  }

  @media (max-width: 749px) {
    .ncdr-inner-hero { padding: 40px 20px 36px; }
    .ncdr-inner-hero__heading { font-size: 32px; }
  }
</style>

<div class="ncdr-inner-hero">
  <div class="ncdr-inner-hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <div class="ncdr-inner-hero__eyebrow">{{ section.settings.eyebrow }}</div>
    {%- endif -%}
    <h1 class="ncdr-inner-hero__heading">
      {{ section.settings.heading }}
      {%- if section.settings.heading_gold != blank -%}
        <span>{{ section.settings.heading_gold }}</span>
      {%- endif -%}
    </h1>
    {%- if section.settings.subtext != blank -%}
      <p class="ncdr-inner-hero__sub">{{ section.settings.subtext }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "NCDR Inner Hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow label" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "heading_gold", "label": "Heading line 2 (gold, optional)" },
    { "type": "textarea", "id": "subtext", "label": "Subtext" }
  ],
  "presets": [
    { "name": "NCDR Inner Hero" }
  ]
}
{% endschema %}
