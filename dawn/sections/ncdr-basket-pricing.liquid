<style>
  .ncdr-basket-pricing {
    padding: 72px 60px;
    background: #fff;
    border-bottom: 1px solid var(--ncdr-light-gray);
  }

  .ncdr-basket-pricing__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .ncdr-basket-pricing__title {
    font-family: var(--ncdr-font-heading);
    font-size: 64px;
    font-weight: 700;
    color: var(--ncdr-green-deep);
    letter-spacing: 0.01em;
    margin-bottom: 12px;
    line-height: 1.05;
  }

  .ncdr-basket-pricing__tagline {
    font-size: 15px;
    color: var(--ncdr-mid-gray);
    font-weight: 300;
    margin-bottom: 14px;
    line-height: 1.6;
  }

  .ncdr-basket-pricing__coupon {
    font-size: 11px;
    color: var(--ncdr-green);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-bottom: 1px solid rgba(58,88,43,0.3);
    padding-bottom: 1px;
    text-decoration: none;
  }

  .ncdr-basket-pricing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 900px;
    margin: 0 auto;
  }

  /* ── Non-featured card ── */
  .ncdr-basket-card {
    border: 1px solid var(--ncdr-light-gray);
    border-radius: 10px;
    padding: 36px 28px 32px;
    text-align: center;
    background: #fff;
  }

  /* ── Featured card ── */
  .ncdr-basket-card--featured {
    border: 2px solid var(--ncdr-gold);
    background: var(--ncdr-green-deep);
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(58,88,43,0.25);
    position: relative;
  }

  .ncdr-basket-card__badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--ncdr-gold);
    color: var(--ncdr-green-deep);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 14px;
    border-radius: 2px;
    white-space: nowrap;
  }

  .ncdr-basket-card__name {
    font-size: 20px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--ncdr-mid-gray);
    margin-bottom: 20px;
  }
  .ncdr-basket-card--featured .ncdr-basket-card__name { color: rgba(255,255,255,0.5); }

  .ncdr-basket-card__price {
    font-size: 72px;
    font-weight: 700;
    color: var(--ncdr-green-deep);
    line-height: 1;
    margin-bottom: 6px;
  }
  .ncdr-basket-card--featured .ncdr-basket-card__price { color: var(--ncdr-gold); }

  .ncdr-basket-card__per {
    font-size: 13px;
    color: var(--ncdr-mid-gray);
    margin-bottom: 0;
  }
  .ncdr-basket-card--featured .ncdr-basket-card__per { color: rgba(255,255,255,0.35); }

  .ncdr-basket-card__divider {
    border: none;
    border-top: 1px solid var(--ncdr-light-gray);
    margin: 20px 0 0;
  }
  .ncdr-basket-card--featured .ncdr-basket-card__divider { border-top-color: rgba(255,255,255,0.1); }

  .ncdr-basket-card__features {
    display: flex;
    flex-direction: column;
  }

  .ncdr-basket-card__feature {
    font-size: 15px;
    color: var(--ncdr-mid-gray);
    padding: 14px 0;
    border-bottom: 1px solid var(--ncdr-light-gray);
    line-height: 1.4;
  }
  .ncdr-basket-card__feature:last-child { border-bottom: none; }
  .ncdr-basket-card--featured .ncdr-basket-card__feature {
    color: rgba(255,255,255,0.75);
    border-bottom-color: rgba(255,255,255,0.08);
  }
  .ncdr-basket-card--featured .ncdr-basket-card__feature:last-child { border-bottom: none; }

  .ncdr-basket-pricing__footer {
    text-align: center;
    font-size: 13px;
    color: var(--ncdr-mid-gray);
    margin-top: 28px;
  }

  @media (max-width: 749px) {
    .ncdr-basket-pricing { padding: 48px 20px; }
    .ncdr-basket-pricing__title { font-size: 40px; }
    .ncdr-basket-pricing__grid { grid-template-columns: 1fr; gap: 28px; }
    .ncdr-basket-card--featured { transform: none; }
    .ncdr-basket-card__price { font-size: 52px; }
  }
</style>

<div class="ncdr-basket-pricing">
  <div class="ncdr-basket-pricing__header">
    <h2 class="ncdr-basket-pricing__title">Basket Pricing</h2>
    {%- if section.settings.heading != blank -%}
      <p class="ncdr-basket-pricing__tagline">{{ section.settings.heading }}</p>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="ncdr-basket-pricing__tagline" style="margin-bottom:10px;">{{ section.settings.subtext }}</p>
    {%- endif -%}
    <a href="{{ section.settings.coupon_link }}" class="ncdr-basket-pricing__coupon">{{ section.settings.coupon_label }}</a>
  </div>

  <div class="ncdr-basket-pricing__grid">
    {%- for block in section.blocks -%}
      <div class="ncdr-basket-card{% if block.settings.featured %} ncdr-basket-card--featured{% endif %}">
        {%- if block.settings.featured and block.settings.badge != blank -%}
          <div class="ncdr-basket-card__badge">{{ block.settings.badge }}</div>
        {%- endif -%}

        <div class="ncdr-basket-card__name">{{ block.settings.name }}</div>

        <div class="ncdr-basket-card__price">${{ block.settings.price }}</div>
        <div class="ncdr-basket-card__per">per basket</div>

        <hr class="ncdr-basket-card__divider">

        <div class="ncdr-basket-card__features">
          {%- if block.settings.feature_1 != blank -%}
            <div class="ncdr-basket-card__feature">{{ block.settings.feature_1 }}</div>
          {%- endif -%}
          {%- if block.settings.feature_2 != blank -%}
            <div class="ncdr-basket-card__feature">{{ block.settings.feature_2 }}</div>
          {%- endif -%}
          {%- if block.settings.feature_3 != blank -%}
            <div class="ncdr-basket-card__feature">{{ block.settings.feature_3 }}</div>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  <p class="ncdr-basket-pricing__footer">All prices are in USD and applicable taxes are added at checkout.</p>
</div>

{% schema %}
{
  "name": "Basket Pricing",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Tagline (below 'Basket Pricing')", "default": "Hit More. Pay Less." },
    { "type": "text", "id": "subtext", "label": "Subtext", "default": "Premium range balls, access to grass tees, and turf mat bays — every basket includes it all." },
    { "type": "text", "id": "coupon_label", "label": "Coupon link label", "default": "Save up to 20% with a Coupon Book →" },
    { "type": "url", "id": "coupon_link", "label": "Coupon link" }
  ],
  "blocks": [
    {
      "type": "basket",
      "name": "Basket Tier",
      "settings": [
        { "type": "text", "id": "name", "label": "Basket name", "default": "Small Basket" },
        { "type": "text", "id": "price", "label": "Price (no $)", "default": "13" },
        { "type": "checkbox", "id": "featured", "label": "Featured (dark card)", "default": false },
        { "type": "text", "id": "badge", "label": "Badge label (if featured)", "default": "Best Value" },
        { "type": "text", "id": "feature_1", "label": "Feature 1", "default": "45 Premium Balls" },
        { "type": "text", "id": "feature_2", "label": "Feature 2", "default": "Access to Grass Tees" },
        { "type": "text", "id": "feature_3", "label": "Feature 3", "default": "Access to Bays with Turf Mats" }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Basket Pricing",
      "blocks": [
        { "type": "basket", "settings": { "name": "Small Basket", "price": "13", "featured": false, "feature_1": "45 Premium Balls", "feature_2": "Access to Grass Tees", "feature_3": "Access to Bays with Turf Mats" } },
        { "type": "basket", "settings": { "name": "Medium Basket", "price": "18", "featured": true, "badge": "Best Value", "feature_1": "90 Premium Balls", "feature_2": "Access to Grass Tees", "feature_3": "Access to Bays with Turf Mats" } },
        { "type": "basket", "settings": { "name": "Large Basket", "price": "22", "featured": false, "feature_1": "140 Premium Balls", "feature_2": "Access to Grass Tees", "feature_3": "Access to Bays with Turf Mats" } }
      ]
    }
  ]
}
{% endschema %}
