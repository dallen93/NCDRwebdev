<style>
  .ncdr-membership-section {
    background: var(--ncdr-off-white);
    padding: 8rem 6rem;
  }

  .ncdr-membership-header {
    text-align: center;
    margin-bottom: 4.8rem;
  }

  .ncdr-membership-header .ncdr-eyebrow {
    justify-content: center;
  }
  .ncdr-membership-header .ncdr-eyebrow::after { display: none; }
  .ncdr-membership-header .ncdr-eyebrow::before {
    content: '';
    display: block;
    width: 3.2rem;
    height: 1px;
    background: var(--ncdr-gold);
    opacity: 0.4;
  }

  .ncdr-membership-title {
    font-family: var(--font-heading-family);
    font-size: 3.6rem;
    font-weight: 600;
    color: var(--ncdr-dark-gray);
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: 8px;
  }

  .ncdr-membership-sub {
    font-size: 1.5rem;
    color: var(--ncdr-mid-gray);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
    font-weight: 300;
  }

  .ncdr-tier-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    align-items: start;
  }

  .ncdr-tier-card {
    border: 1px solid var(--ncdr-light-gray);
    border-radius: 6px;
    padding: 2.8rem 2.2rem;
    position: relative;
    background: #fff;
    transition: all 0.25s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }

  .ncdr-tier-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    border-color: rgba(58,88,43,0.2);
  }

  .ncdr-tier-card.featured {
    border: 2px solid var(--ncdr-gold);
    background: var(--ncdr-green-deep);
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(58,88,43,0.25);
    color: #fff;
  }

  .ncdr-tier-card.featured:hover { transform: translateY(-8px); }

  .ncdr-tier-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--ncdr-gold);
    color: var(--ncdr-green-deep);
    font-family: var(--font-heading-family);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 14px;
    border-radius: 2px;
    white-space: nowrap;
  }

  .ncdr-tier-name {
    font-family: var(--font-heading-family);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ncdr-green);
    margin-bottom: 1.2rem;
  }
  .ncdr-tier-card.featured .ncdr-tier-name { color: rgba(255,255,255,0.5); }

  .ncdr-tier-price {
    font-family: var(--font-heading-family);
    font-size: 4.2rem;
    font-weight: 700;
    color: var(--ncdr-dark-gray);
    line-height: 1;
    margin-bottom: 4px;
  }
  .ncdr-tier-card.featured .ncdr-tier-price { color: var(--ncdr-gold); }
  .ncdr-tier-price sup { font-size: 1.8rem; font-weight: 400; vertical-align: super; }
  .ncdr-tier-price sub { font-size: 1.4rem; font-weight: 400; color: #888; }
  .ncdr-tier-card.featured .ncdr-tier-price sub { color: rgba(255,255,255,0.4); }

  .ncdr-tier-access {
    font-size: 1.2rem;
    color: var(--ncdr-mid-gray);
    margin-bottom: 2rem;
    padding-bottom: 1.6rem;
    border-bottom: 1px solid var(--ncdr-light-gray);
    line-height: 1.5;
  }
  .ncdr-tier-card.featured .ncdr-tier-access {
    color: rgba(255,255,255,0.5);
    border-bottom-color: rgba(255,255,255,0.08);
  }

  .ncdr-tier-cta {
    display: block;
    width: 100%;
    text-align: center;
    background: #fff;
    color: var(--ncdr-green);
    font-family: var(--font-heading-family);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 11px;
    border-radius: 3px;
    cursor: pointer;
    border: 1.5px solid var(--ncdr-green);
    transition: all 0.2s;
    text-decoration: none;
  }
  .ncdr-tier-cta:hover { background: var(--ncdr-green); color: #fff; }
  .ncdr-tier-card.featured .ncdr-tier-cta {
    background: var(--ncdr-gold);
    color: var(--ncdr-green-deep);
    border: none;
  }
  .ncdr-tier-card.featured .ncdr-tier-cta:hover { background: var(--ncdr-gold-light); }

  .ncdr-tier-note {
    text-align: center;
    margin-top: 10px;
    font-size: 1rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.04em;
  }
  .ncdr-tier-card:not(.featured) .ncdr-tier-note { color: #888; }

  @media (max-width: 749px) {
    .ncdr-membership-section { padding: 4.8rem 2rem; }
    .ncdr-tier-grid { grid-template-columns: 1fr; }
    .ncdr-tier-card.featured { transform: none; }
  }
</style>

<div class="ncdr-membership-section">
  <div class="ncdr-membership-header">
    <p class="ncdr-eyebrow">Membership</p>
    <h2 class="ncdr-membership-title">{{ section.settings.heading }}</h2>
    <p class="ncdr-membership-sub">{{ section.settings.subheading }}</p>
  </div>

  <div class="ncdr-tier-grid">
    {%- for block in section.blocks -%}
      <div class="ncdr-tier-card{% if block.settings.featured %} featured{% endif %}" {{ block.shopify_attributes }}>
        {%- if block.settings.featured and block.settings.badge != blank -%}
          <div class="ncdr-tier-badge">{{ block.settings.badge }}</div>
        {%- endif -%}
        <div class="ncdr-tier-name">{{ block.settings.name }}</div>
        <div class="ncdr-tier-price"><sup>$</sup>{{ block.settings.price }}<sub>/mo</sub></div>
        <div class="ncdr-tier-access">{{ block.settings.access }}</div>
        <a href="{{ block.settings.link | default: '/pages/memberships' }}" class="ncdr-tier-cta">
          {{ block.settings.cta_label | default: 'Join Now' }}
        </a>
        {%- if block.settings.note != blank -%}
          <div class="ncdr-tier-note">{{ block.settings.note }}</div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "NCDR Memberships",
  "tag": "div",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Section Heading", "default": "Find Your Plan" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Every member receives a digital badge in Apple & Google Wallet, member pricing, and priority access." }
  ],
  "blocks": [
    {
      "type": "tier",
      "name": "Membership Tier",
      "settings": [
        { "type": "text", "id": "name", "label": "Tier Name", "default": "Early Bird" },
        { "type": "text", "id": "price", "label": "Monthly Price (number only)", "default": "49" },
        { "type": "text", "id": "access", "label": "Access Description", "default": "Morning & daytime access only" },
        { "type": "checkbox", "id": "featured", "label": "Featured card", "default": false },
        { "type": "text", "id": "badge", "label": "Featured Badge Label", "default": "Best Value" },
        { "type": "text", "id": "cta_label", "label": "Button Label", "default": "Join Now" },
        { "type": "url", "id": "link", "label": "Button Link" },
        { "type": "text", "id": "note", "label": "Footer Note (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "NCDR Memberships",
      "blocks": [
        { "type": "tier", "settings": { "name": "Early Bird", "price": "49", "access": "Morning & daytime access only" } },
        { "type": "tier", "settings": { "name": "Very Long Day Pass", "price": "59", "access": "Evenings 8pm through close", "featured": true, "badge": "Best Value", "note": "Most popular plan at NCDR" } },
        { "type": "tier", "settings": { "name": "Anytime", "price": "89", "access": "Full access, any time we're open" } },
        { "type": "tier", "settings": { "name": "Founding Member", "price": "79", "access": "Anytime access, rate locked for life", "cta_label": "Claim Your Spot", "note": "50 spots only — 12 remaining" } }
      ]
    }
  ]
}
{% endschema %}
